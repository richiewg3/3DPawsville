{
  "name": "3dpawsville",
  "version": "1.0.0",
  "private": true,
  "description": "Foundational 3D browser game scaffold with automated asset pipeline.",
  "type": "module",
  "scripts": {
    "extract:assets": "node scripts/extract-assets.mjs",
    "convert:map": "node scripts/convert-map-to-glb.mjs",
    "prepare:assets": "npm run extract:assets && npm run convert:map",
    "predev": "npm run prepare:assets",
    "dev": "vite",
    "prebuild": "npm run prepare:assets",
    "build": "vite build",
    "preview": "vite preview"
  },
  "dependencies": {
    "three": "^0.184.0"
  },
  "devDependencies": {
    "adm-zip": "^0.5.17",
    "obj2gltf": "^3.2.0",
    "vite": "^8.0.9"
  }
}
